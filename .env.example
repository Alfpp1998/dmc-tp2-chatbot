# Copy this file to .env and fill only the values you need.
# .env is ignored by git.

# Hugging Face token.
# Optional for public models, useful for higher rate limits and faster downloads.
HF_TOKEN=

# API answering providers.
QWEN_API_KEY=
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=

# Local Hugging Face and Ollama answering:
# Select provider/model at runtime in Streamlit or the notebook.
# Hugging Face models may download on first use.
# Ollama requires Ollama running separately and the selected model pulled locally.
OLLAMA_BASE_URL=http://localhost:11434
